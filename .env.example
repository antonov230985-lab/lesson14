# ============================================================
# Урок 14 — пример файла .env
# ============================================================
# Как использовать:
# 1) Скопируй этот файл как .env (в корне проекта).
# 2) Заполни обязательные поля ниже.
# 3) Не коммить .env в git (там секреты).
#
# Минимум для запуска app.py:
# - YANDEX_TOKEN
# - GOOGLE_SERVICE_ACCOUNT_FILE
# - GOOGLE_DRIVE_FILE_ID
#
# ВАЖНО: значения после "=" пишутся без кавычек.

# OAuth-токен Яндекс.Диска.
# Где взять: OAuth-приложение Яндекса/токен для API Disk.
# Пример: AQAAAAABcD...<длинная строка>...
YANDEX_TOKEN=

# Путь к JSON-ключу service account Google.
# Где взять: Google Cloud Console -> Service Accounts -> Keys -> JSON.
# Пример (Windows): C:/Users/you/keys/lesson14-service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=

# ID исходного файла в Google Drive, который нужно отслеживать.
# Берется из URL файла:
# https://drive.google.com/file/d/<ЭТОТ_ID>/view
GOOGLE_DRIVE_FILE_ID=

# Путь к входному файлу на Яндекс.Диске (источник).
# Может быть просто имя в корне диска или путь к папке.
# Примеры: homework_lesson13.xlsx  или  /lesson14/homework_lesson13.xlsx
YANDEX_INPUT_PATH=homework_lesson13.xlsx

# Путь назначения итогового файла на Яндекс.Диске.
# Пример: /lesson14/lesson14_all_tasks_clean.xlsx
YANDEX_OUTPUT_PATH=lesson14_all_tasks_clean.xlsx

# Имя итогового файла для Google Drive (используется при создании нового файла).
GOOGLE_OUTPUT_NAME=lesson14_all_tasks_clean.xlsx

# Интервал проверки изменений в секундах.
# Пример: 30 = проверка каждые 30 секунд.
POLLING_SECONDS=30

# Локальный файл состояния (сохраняет последние версии файлов из облаков).
STATE_FILE=.sync_state.json

# Локальная временная директория для промежуточных файлов.
TEMP_ROOT=.tmp_sync
